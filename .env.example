# ─── Vercel project env vars ─────────────────────────────
# Set in Vercel project settings (Production + Preview).
# The PC-side status pusher uses the same value to authenticate.
STATUS_PUSH_SECRET=

# Firebase admin credentials, used by /api/status to persist the
# Hermes snapshot in Firestore (collection `status`, doc `hermes`).
# Generate at: Firebase Console → Project Settings → Service Accounts
# → Generate new private key. Then base64-encode the downloaded JSON:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("sa.json"))
#   macOS/Linux: base64 -w0 sa.json
FIREBASE_SERVICE_ACCOUNT_B64=

# ─── Alerts + budget (Phase 4) ───────────────────────────────────────
# Set in Vercel project settings. Telegram is the same channel Kai uses to
# talk to Hermes; alerts (fleet offline, budget cap, failed runs) post here.
# TELEGRAM_BOT_TOKEN=     (BotFather token; unset = alerting disabled)
# TELEGRAM_CHAT_ID=       (chat/channel id to notify)
# MONTHLY_BUDGET_USD=10   (budget cap for the HUD gauge + cap alert)
# STALE_SECONDS=600       (no Hermes heartbeat for this long → offline alert)
# CRON_SECRET=            (Vercel sends it as a Bearer on cron requests;
#                          set it to lock /api/cron/staleness)
# APP_URL=https://kai-asset-forge-hub.vercel.app  (used in alert deep-links)

# ─── PC-side env vars (consumed by scripts/hermes-status-pusher.ps1) ─
# Set in the user account's environment, not in this repo.
# HERMES_LOCAL_URL=http://localhost:8642
# HERMES_LOCAL_TOKEN=   (Hermes bearer key; required now that the API server
#                        enforces auth — same value as HERMES_API_KEY below)
# KAI_VERCEL_URL=https://kai-asset-forge-hub.vercel.app
# STATUS_PUSH_SECRET=   (same value as above)

# ─── Hermes fleet env vars (consumed by hermes/agent.js) ────────────
# Set in the fleet's runtime env (hermes/docker-compose.yml). The fleet now
# pushes live telemetry into the durable runs store on the hub, so it needs
# STATUS_PUSH_SECRET (same value as above) to authenticate those writes.
# ROLE=orchestrator        (orchestrator | lister | monitor)
# KAI_API_BASE=https://kai-asset-forge-hub.vercel.app
# KAI_API_TOKEN=           (bearer for /api/agents/* — the production endpoints)
# POLL_SECONDS=10          (inbox poll cadence; orchestrator/lister)
# HEARTBEAT_MINUTES=30     (orchestrator health heartbeat)
# MONITOR_MINUTES=5        (monitor role: fleet-health snapshot cadence)
# STATUS_PUSH_SECRET=      (auth for run-telemetry + /api/status pushes)

# ─── Cloud-bridge env vars (consumed by scripts/hermes-call.sh) ──────
# Set these in the Claude Code CLOUD environment settings (gear next to the
# environment name → Environment variables), NOT in this repo. They let a
# cloud Claude Code session reach the home-PC Hermes agent through the
# Cloudflare Tunnel. See CLAUDE.md → "Reaching the home-PC Hermes agent".
# The cloud environment's network policy must allow egress to the tunnel host
# (use the "Custom" allowlist and add hermes.masta-kai.dev).
# HERMES_URL=https://hermes.masta-kai.dev
# CF_ACCESS_CLIENT_ID=        (Cloudflare Access service-token id)
# CF_ACCESS_CLIENT_SECRET=    (Cloudflare Access service-token secret — auth layer 1)
# HERMES_API_KEY=             (Hermes bearer key — auth layer 2)
