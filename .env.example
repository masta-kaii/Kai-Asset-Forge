# ─── Vercel project env vars ─────────────────────────────
# Set in Vercel project settings (Production + Preview).
# The PC-side status pusher uses the same value to authenticate.
STATUS_PUSH_SECRET=

# ─── Cloud Claude Code session env vars ──────────────────
# Configure these in your Claude Code on the web environment
# settings, NOT in this repo. They let a remote session
# delegate work to Hermes-on-PC via the Cloudflare Tunnel.
KAI_HERMES_URL=https://hermes.your-domain.example
KAI_HERMES_TOKEN=

# ─── PC-side env vars (consumed by scripts/hermes-status-pusher.ps1) ─
# Set in the user account's environment, not in this repo.
# HERMES_LOCAL_URL=http://localhost:8642
# HERMES_LOCAL_TOKEN=   (optional; only set if you've enabled Hermes' bearer auth)
# KAI_VERCEL_URL=https://kai-asset-forge-hub.vercel.app
# STATUS_PUSH_SECRET= (same value as above)
