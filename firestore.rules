rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Assets ===
    match /assets/{assetId} {
      allow read, write: if request.auth != null;
      // Indexes: type, status, style, tags, createdAt
    }

    // === Prompts ===
    match /prompts/{promptId} {
      allow read, write: if request.auth != null;
    }

    // === Asset Packs ===
    match /assetPacks/{packId} {
      allow read, write: if request.auth != null;
    }

    // === Generation Records ===
    match /generations/{generationId} {
      allow read, write: if request.auth != null;
      // Indexes: assetId, agentName, createdAt
    }

    // === Workflows ===
    match /workflows/{workflowId} {
      allow read, write: if request.auth != null;
      // Indexes: status, workflowType, assignedAgent
    }

    // === User Profile / Settings ===
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // === Masta Conversations (per-user) ===
    match /masta_chats/{userId}/messages/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // === Masta Daily Digests (cron-written) ===
    // NOTE: cron writes via the client SDK like the rest of the app, so
    // tighten this to an Admin-SDK setup before going to production.
    match /masta_digests/{digestId} {
      allow read, write: if request.auth != null;
    }

    // === Cron audit log ===
    match /cron_runs/{runId} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
